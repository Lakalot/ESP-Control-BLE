{
  "expo": {
    "name": "ESP Control BLE",
    "slug": "esp-control-ble",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "esp-control-ble",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#181825"
    },
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.amazing.espcontrolble",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "L'app utilise le Bluetooth pour communiquer avec vos ESP32.",
        "NSBluetoothPeripheralUsageDescription": "L'app utilise le Bluetooth pour communiquer avec vos ESP32."
      }
    },
    "android": {
      "package": "com.amazing.espcontrolble",
      "permissions": [
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "L'app utilise le Bluetooth pour communiquer avec vos ESP32."
        }
      ]
    ]
  }
}
