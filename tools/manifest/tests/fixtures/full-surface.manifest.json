{
  "version": 5,
  "schemaVersion": 1,
  "minAppVersion": "1.0.0",
  "capabilities": {
    "required": ["layout.sections", "rules.visibility"],
    "optional": []
  },
  "appShell": {
    "navBar": {
      "items": [
        {
          "id": "home",
          "label": "Home",
          "icon": "home",
          "viewId": "home"
        },
        {
          "id": "stats",
          "label": "Stats",
          "icon": "bar-chart-2",
          "viewId": "stats"
        },
        {
          "id": "settings",
          "label": "Settings",
          "icon": "settings",
          "viewId": "settings"
        }
      ]
    }
  },
  "resources": [
    {
      "id": "relay.auto",
      "firmwareSymbol": "relay_auto",
      "label": "Main Power",
      "valueType": "bool",
      "readMode": "subscribe",
      "staleAfterMs": 5000
    },
    {
      "id": "light.brightness",
      "firmwareSymbol": "light_brightness",
      "label": "Brightness",
      "valueType": "uint",
      "unit": "%",
      "readMode": "subscribe",
      "staleAfterMs": 5000
    },
    {
      "id": "env.temperature",
      "firmwareSymbol": "env_temperature",
      "label": "Temperature",
      "valueType": "float",
      "unit": "C",
      "readMode": "subscribe",
      "staleAfterMs": 5000
    },
    {
      "id": "fan.profile",
      "firmwareSymbol": "fan_profile",
      "label": "Fan Profile",
      "valueType": "enum",
      "readMode": "subscribe",
      "staleAfterMs": 5000,
      "enumValues": ["slow", "normal", "fast"]
    },
    {
      "id": "system.load",
      "firmwareSymbol": "system_load",
      "label": "Load",
      "valueType": "uint",
      "unit": "%",
      "readMode": "subscribe",
      "staleAfterMs": 3000
    },
    {
      "id": "device.debug",
      "firmwareSymbol": "device_debug",
      "label": "Debug Mode",
      "valueType": "bool",
      "readMode": "snapshot",
      "staleAfterMs": 10000
    },
    {
      "id": "env.humidity",
      "firmwareSymbol": "env_humidity",
      "label": "Humidity",
      "valueType": "float",
      "unit": "%",
      "readMode": "subscribe",
      "staleAfterMs": 5000
    },
    {
      "id": "wifi.rssi",
      "firmwareSymbol": "wifi_rssi",
      "label": "WiFi Signal",
      "valueType": "int",
      "unit": "dBm",
      "readMode": "poll",
      "pollMs": 10000,
      "staleAfterMs": 15000
    },
    {
      "id": "system.uptime",
      "firmwareSymbol": "system_uptime",
      "label": "Uptime",
      "valueType": "duration_ms",
      "readMode": "poll",
      "pollMs": 5000,
      "staleAfterMs": 10000
    },
    {
      "id": "device.name",
      "firmwareSymbol": "device_name",
      "label": "Device Name",
      "valueType": "string",
      "readMode": "snapshot",
      "staleAfterMs": 60000
    },
    {
      "id": "light.color",
      "firmwareSymbol": "light_color",
      "label": "Color Preset",
      "valueType": "enum",
      "readMode": "subscribe",
      "staleAfterMs": 5000,
      "enumValues": ["warm_white", "cool_white", "red", "green", "blue", "party"]
    }
  ],
  "actions": [
    {
      "id": "relay.toggle",
      "firmwareSymbol": "relay_toggle",
      "label": "Toggle",
      "dangerLevel": "normal",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      }
    },
    {
      "id": "light.set_brightness",
      "firmwareSymbol": "light_set_brightness",
      "label": "Set Brightness",
      "dangerLevel": "normal",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value"],
        "properties": {
          "value": { "type": "integer", "minimum": 0, "maximum": 100 }
        }
      }
    },
    {
      "id": "fan.set_profile",
      "firmwareSymbol": "fan_set_profile",
      "label": "Set Fan Profile",
      "dangerLevel": "normal",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value"],
        "properties": {
          "value": { "type": "string", "enum": ["slow", "normal", "fast"] }
        }
      }
    },
    {
      "id": "device.set_debug",
      "firmwareSymbol": "device_set_debug",
      "label": "Set Debug Mode",
      "dangerLevel": "elevated",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value"],
        "properties": {
          "value": { "type": "boolean" }
        }
      }
    },
    {
      "id": "system.factory_reset",
      "firmwareSymbol": "system_factory_reset",
      "label": "Factory Reset",
      "dangerLevel": "dangerous",
      "confirm": "This will erase all settings. Continue?",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      }
    },
    {
      "id": "device.rename",
      "firmwareSymbol": "device_rename",
      "label": "Rename Device",
      "dangerLevel": "normal",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value"],
        "properties": {
          "value": { "type": "string", "minLength": 1, "maxLength": 32 }
        }
      }
    },
    {
      "id": "light.set_color",
      "firmwareSymbol": "light_set_color",
      "label": "Set Color",
      "dangerLevel": "normal",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value"],
        "properties": {
          "value": { "type": "string", "enum": ["warm_white", "cool_white", "red", "green", "blue", "party"] }
        }
      }
    },
    {
      "id": "system.restart",
      "firmwareSymbol": "system_restart",
      "label": "Restart",
      "dangerLevel": "dangerous",
      "confirm": "Restart the device now?",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      }
    }
  ],
  "views": [
    {
      "id": "home",
      "firmwareSymbol": "home",
      "title": "Home",
      "routeKey": "home",
      "entryRules": [
        {
          "var": "resource.relay.auto"
        }
      ],
      "rootNodeId": "home.root"
    },
    {
      "id": "stats",
      "firmwareSymbol": "stats_screen",
      "title": "Stats",
      "routeKey": "stats",
      "entryRules": [
        {
          "==": [
            {
              "var": "resource.fan.profile"
            },
            "normal"
          ]
        }
      ],
      "rootNodeId": "stats.root"
    },
    {
      "id": "settings",
      "firmwareSymbol": "settings_screen",
      "title": "Settings",
      "routeKey": "settings",
      "rootNodeId": "settings.root"
    }
  ],
  "nodes": [
    {
      "id": "home.root",
      "firmwareSymbol": "home_root",
      "kind": "stack",
      "children": ["home.banner", "lighting.section"]
    },
    {
      "id": "stats.root",
      "firmwareSymbol": "stats_root",
      "kind": "stack",
      "children": ["telemetry.section", "system.section"]
    },
    {
      "id": "settings.root",
      "firmwareSymbol": "settings_root",
      "kind": "stack",
      "children": ["settings.section", "advanced.section"]
    },
    {
      "id": "home.banner",
      "firmwareSymbol": "home_banner",
      "kind": "widget",
      "widget": "text",
      "title": "ESP Control",
      "text": "BLE-connected device dashboard."
    },
    {
      "id": "lighting.section",
      "firmwareSymbol": "lighting_section",
      "kind": "section",
      "title": "Lighting",
      "children": ["lighting.toggle", "lighting.slider", "lighting.color"]
    },
    {
      "id": "lighting.toggle",
      "firmwareSymbol": "lighting_toggle",
      "kind": "widget",
      "widget": "toggle",
      "title": "Main Power",
      "bind": {
        "resource": "relay.auto",
        "action": "relay.toggle"
      }
    },
    {
      "id": "lighting.slider",
      "firmwareSymbol": "lighting_slider",
      "kind": "widget",
      "widget": "slider",
      "title": "Brightness",
      "bind": {
        "resource": "light.brightness",
        "action": "light.set_brightness"
      },
      "formatHint": "percent"
    },
    {
      "id": "lighting.color",
      "firmwareSymbol": "lighting_color",
      "kind": "widget",
      "widget": "select",
      "title": "Color Preset",
      "bind": {
        "resource": "light.color",
        "action": "light.set_color"
      }
    },
    {
      "id": "telemetry.section",
      "firmwareSymbol": "telemetry_section",
      "kind": "section",
      "title": "Telemetry",
      "children": ["telemetry.temp", "telemetry.humidity", "telemetry.load", "telemetry.profile"]
    },
    {
      "id": "telemetry.temp",
      "firmwareSymbol": "telemetry_temp",
      "kind": "widget",
      "widget": "stat",
      "title": "Temperature",
      "bind": {
        "resource": "env.temperature"
      },
      "formatHint": "float_2"
    },
    {
      "id": "telemetry.humidity",
      "firmwareSymbol": "telemetry_humidity",
      "kind": "widget",
      "widget": "stat",
      "title": "Humidity",
      "bind": {
        "resource": "env.humidity"
      },
      "formatHint": "float_1"
    },
    {
      "id": "telemetry.load",
      "firmwareSymbol": "telemetry_load",
      "kind": "widget",
      "widget": "stat",
      "title": "Load",
      "bind": {
        "resource": "system.load"
      },
      "formatHint": "percent"
    },
    {
      "id": "telemetry.profile",
      "firmwareSymbol": "telemetry_profile",
      "kind": "widget",
      "widget": "select",
      "title": "Fan Profile",
      "bind": {
        "resource": "fan.profile",
        "action": "fan.set_profile"
      }
    },
    {
      "id": "system.section",
      "firmwareSymbol": "system_section",
      "kind": "section",
      "title": "System",
      "children": ["system.row"]
    },
    {
      "id": "system.row",
      "firmwareSymbol": "system_row",
      "kind": "row",
      "children": ["system.rssi", "system.uptime"]
    },
    {
      "id": "system.rssi",
      "firmwareSymbol": "system_rssi",
      "kind": "widget",
      "widget": "badge",
      "title": "WiFi",
      "bind": {
        "resource": "wifi.rssi"
      }
    },
    {
      "id": "system.uptime",
      "firmwareSymbol": "system_uptime",
      "kind": "widget",
      "widget": "timer",
      "title": "Uptime",
      "bind": {
        "resource": "system.uptime"
      }
    },
    {
      "id": "settings.section",
      "firmwareSymbol": "settings_section",
      "kind": "section",
      "title": "Device",
      "children": ["settings.rename", "settings.restart"]
    },
    {
      "id": "advanced.section",
      "firmwareSymbol": "advanced_section",
      "kind": "section",
      "title": "Advanced",
      "children": ["advanced.debug", "advanced.note", "advanced.reset"]
    },
    {
      "id": "advanced.debug",
      "firmwareSymbol": "advanced_debug",
      "kind": "widget",
      "widget": "toggle",
      "title": "Debug Mode",
      "bind": {
        "resource": "device.debug",
        "action": "device.set_debug"
      }
    },
    {
      "id": "advanced.note",
      "firmwareSymbol": "advanced_note",
      "kind": "widget",
      "widget": "text",
      "text": "Advanced settings"
    },
    {
      "id": "advanced.reset",
      "firmwareSymbol": "advanced_reset",
      "kind": "widget",
      "widget": "button",
      "title": "Factory Reset",
      "bind": {
        "action": "system.factory_reset"
      }
    },
    {
      "id": "settings.rename",
      "firmwareSymbol": "settings_rename",
      "kind": "widget",
      "widget": "text_input",
      "title": "Rename Device",
      "bind": {
        "resource": "device.name",
        "action": "device.rename"
      }
    },
    {
      "id": "settings.restart",
      "firmwareSymbol": "settings_restart",
      "kind": "widget",
      "widget": "button",
      "title": "Restart",
      "bind": {
        "action": "system.restart"
      }
    }
  ]
}
